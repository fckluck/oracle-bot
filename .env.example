  CODEX_API_KEY=your_codex_key
  SESSION_SECRET=random_string_for_sessions

  # xAI Grok Soul Layer
  XAI_API_KEY=your_xai_api_key_here

  # Audit config
  OWNER_TELEGRAM_ID=your_telegram_user_id